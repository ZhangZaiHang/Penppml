******************************************************************************************************************************
******************************************************************************************************************************
***
*** Table 4-6 Descriptive Statistics of the Regression Variable Coefficients
*** 
******************************************************************************************************************************
******************************************************************************************************************************
* ==============================================================================
* 回归系数的描述性统计
* ==============================================================================
	estimates use "${usr_data}\1991_2021.ster"
	estimates describe
	estimates replay

* 1. 提取回归后的系数向量 e(b) 和 协方差矩阵 e(V)
	matrix b = e(b)
	matrix V = e(V)

	local col_names : colnames b
	local valid_count = 0

* 2. 遍历并提取所有有效的系数，拼接成一个列向量 (Column Vector)
	local i = 1
	foreach var in `col_names' {
		if "`var'" != "_cons" {
			* 检查变量是否有效（方差不为0）
			if el(V, `i', `i') != 0 {
				local valid_count = `valid_count' + 1
				if `valid_count' == 1 {
					matrix valid_b = b[1, `i']
				}
				else {
					* 将新提取的系数按行追加到 valid_b 矩阵下方
					matrix valid_b = valid_b \ b[1, `i']
				}
			}
		}
		local i = `i' + 1
	}

* 3. 检查防错
	if `valid_count' == 0 {
		display as error "错误：没有找到有效的回归系数！"
		exit
	}

* 4. 使用 preserve 保护原数据，将矩阵转化为变量进行统计
	preserve
	clear  // 暂时清空数据空间，不会影响你硬盘上的数据
	quietly svmat valid_b, names(coef)  // 将矩阵变成名为 coef1 的变量

* 5. 输出详细的描述性统计（均值、标准差、最小、最大、中位数等）
	display ""
	display "{hline 62}"
	display "  `valid_count' 个实际参与回归的交互项系数的描述性统计"
	display "{hline 62}"
	summarize coef1, detail

	restore  // 完美恢复你原本的数据集，一切就像没发生过一样
* ==============================================================================




