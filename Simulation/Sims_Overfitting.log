. 
. // 设置模拟参数
. qui local rep = 1000       // 重复次数

. qui local od  = 0.3        // 过度分散参数

. qui local beta = 0.2       // x1 的真实系数

. 
. // --- 开始主循环 ---
. foreach obs in 250 1000 4000 { 
  2.     qui local tph = 100 + `obs' // 训练集 + 100个测试集观测
  3.     
.     foreach rho in 0.99 0.90 0.75 { 
  4.         foreach f in 5 10 20 { 
  5.             
.             // 动态设置变量总数 P
.             qui local p = 5*ceil(sqrt(`obs'))
  6.             qui local smpl= max(`tph',`rep')
  7.             qui set obs `smpl'
  8.             
.             // --- 1. 初始化结果存储变量 ---
.             
.             // 预测误差 (MSPE) 存储变量
.             qui g mspe_under = .  // 欠拟合 (Under-fit)
  9.             qui g mspe_ideal = .  // 理想拟合 (Ideal-fit)
 10.             qui g mspe_full  = .  // 过拟合 (Full Model / Over-fit)
 11.             qui g mspe_lcv   = .  // Lasso CV
 12.             
.             // 变量选择 (Selection) 存储变量 (仅针对 Lasso CV)
.             qui g sel_lcv_x1 = .  // 是否正确选中 x1 (1=是, 0=否)
 13.             qui g num_vars   = .  // Lasso 选中的变量总数
 14.             
.             // 随机数种子，保证可重复性
.             set seed 20022021
 15.             qui local f1 = `f' + 1
 16. 
.             // --- 2. 模拟循环 (replications) ---
.             forvalues r = 1/`rep' { 
 17.                 
.                 // A. 数据生成 (DGP) - 与原代码保持一致
.                 // 生成相关系数矩阵 V
.                 mat v = J(`f',`f',`rho') + (1-`rho')*I(`f')
 18.                 
.                 // 生成 x 变量
.                 drawnorm x1-x`f', corr(v) cstorage(full) 
 19.                 drawnorm x`f1'-x`p'
 20.                 
.                 // 生成 z 和 y
.                 qui g z = rnormal()
 21.                 qui g y = (exp(1 + `beta'*x1 + z + `od'*rnormal())) if _n <= `tph'
 22.                 
.                 // 定义训练集范围
.                 local train "if _n <= `obs'"
 23.                 // 定义测试集范围 (out-of-sample)
.                 local test  "if _n <= `tph' & _n > `obs'"
 24. 
.                 // ---------------------------------------------
.                 // B. 模型 1: 欠拟合 (Under-fitting)
.                 // ---------------------------------------------
.                 // 仅使用 z，漏掉 x1
.                 capture poisson y (z) `train'
 25.                 if _rc == 0 {
 26.                     qui predict fit_u `test', n
 27.                     qui g res_sq = (y - fit_u)^2 `test'
 28.                     su res_sq `test', meanonly
 29.                     qui replace mspe_under = r(mean) in `r'
 30.                     drop fit_u res_sq
 31.                 }
 32. 
.                 // ---------------------------------------------
.                 // C. 模型 2: 理想拟合 (Ideal-fitting / Oracle)
.                 // ---------------------------------------------
.                 // 仅使用真实变量 z 和 x1
.                 capture poisson y (z) x1 `train'
 33.                 if _rc == 0 {
 34.                     qui predict fit_i `test', n
 35.                     qui g res_sq = (y - fit_i)^2 `test'
 36.                     su res_sq `test', meanonly
 37.                     qui replace mspe_ideal = r(mean) in `r'
 38.                     drop fit_i res_sq
 39.                 }
 40. 
.                 // ---------------------------------------------
.                 // D. 模型 3: 过拟合 (Over-fitting / Full Model)
.                 // ---------------------------------------------
.                 // 使用所有变量 z, x1...xp (无惩罚)
.                 // 注意：如果 p 接近或大于 N，此步可能不收敛或存在共线性
.                 capture poisson y (z) x* `train'
 41.                 if _rc == 0 {
 42.                     qui predict fit_f `test', n
 43.                     qui g res_sq = (y - fit_f)^2 `test'
 44.                     su res_sq `test', meanonly
 45.                     qui replace mspe_full = r(mean) in `r'
 46.                     drop fit_f res_sq
 47.                 }
 48. 
.                 // ---------------------------------------------
.                 // E. 模型 4: Lasso CV
.                 // ---------------------------------------------
.                 capture lasso poisson y (z) x* `train', selection(cv)
 49.                 if _rc == 0 {
 50.                     // 1. 记录预测误差
.                     qui predict fit_l `test', n
 51.                     qui g res_sq = (y - fit_l)^2 `test'
 52.                     su res_sq `test', meanonly
 53.                     qui replace mspe_lcv = r(mean) in `r'
 54.                     drop fit_l res_sq
 55.                     
.                     // 2. 记录变量选择情况
.                     // 记录非零系数个数 (减去常数项)
.                     qui replace num_vars = e(k_nonzero_sel) in `r'
 56.                     
.                     // 检查 x1 是否被选中
.                     local selected_vars `e(othervars_sel)'
 57.                     local match = 0
 58.                     foreach v in `selected_vars' {
 59.                         if "`v'" == "x1" {
 60.                             local match = 1
 61.                         }
 62.                     }
 63.                     qui replace sel_lcv_x1 = `match' in `r'
 64.                 }
 65.                 
.                 // 清理生成的数据，准备下一轮
.                 drop y x* z
 66.             } // End Loop r
 67. 
.             // --- 3. 结果汇报 ---
.             di _dup(60) "-"
 68.             di "参数: N=`obs', Rho=`rho', f=`f', Total Vars(P)=`p'"
 69.             di "MSPE 比较 (越小越好):"
 70.             su mspe_under mspe_ideal mspe_full mspe_lcv
 71.             
.             di "Lasso CV 变量选择表现:"
 72.             di "  - x1 选中率 (Target: 1.0):"
 73.             su sel_lcv_x1
 74.             di "  - 平均选中变量数 (Target: 1, Ideal Model has 1 'x'):"
 75.             su num_vars
 76.             di _dup(60) "-"
 77.             
.             // 清理存储变量以便下一次外层循环使用
.             drop mspe_* sel_* num_vars
 78. 
.         } // End Loop f
 79.     } // End Loop rho
 80. } // End Loop obs
